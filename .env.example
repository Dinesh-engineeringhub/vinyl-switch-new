# Copy this file to ".env" only if you use a process manager that loads it,
# OR set these as real environment variables before `npm start`.
# On Windows PowerShell, set one like:  $env:ADMIN_TOKEN = "my-secret"

PORT=3000                     # HTTP port for the booking app + API
MQTT_PORT=1883                # MQTT port the ESP32 devices connect to
SESSION_MINUTES=60            # length of one rental session

# Bookable time grid
OPEN_HOUR=9                   # venue opens (24h clock)
CLOSE_HOUR=22                 # venue closes; sessions must end by this
SLOT_INTERVAL_MINUTES=10      # gap between selectable start times
BOOKING_DAYS=3                # how many days ahead customers can book

GRACE_MINUTES=15              # how early/late a code may be used around the slot

# CHANGE THESE TWO before going live:
DEVICE_PASSWORD=Device@123   # must match MQTT_PASS in the ESP32 firmware
ADMIN_TOKEN=1a2b3c4d5e   # password for the staff dashboard

DB_FILE=data/vinylswitch.db

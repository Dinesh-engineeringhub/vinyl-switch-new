# Vinyl Switch — PRODUCTION config.
# Copy to .env  ->  cp .env.production.example .env  ->  then edit the secrets below.
#
# ⚠️  This server is on the public internet. Use LONG, RANDOM secrets.
#     Generate one with:  openssl rand -hex 24

PORT=3000
MQTT_PORT=1883

# Booking rules
SESSION_MINUTES=60
OPEN_HOUR=8
CLOSE_HOUR=20
SLOT_INTERVAL_MINUTES=10
BOOKING_DAYS=3
GRACE_MINUTES=15

# ───────── CHANGE THESE TWO ─────────
# DEVICE_PASSWORD protects your MQTT broker — every ESP32 must send it,
# and it must match MQTT_PASS in the firmware.
DEVICE_PASSWORD=CHANGE_ME_long_random_device_secret
# ADMIN_TOKEN protects the /admin API (machine + location management).
ADMIN_TOKEN=CHANGE_ME_long_random_admin_token
# ────────────────────────────────────

# Database file (inside the container volume — leave as-is for Docker).
DB_FILE=/app/data/vinylswitch.db
